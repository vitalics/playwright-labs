{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2022"],
    "target": "ES2020",
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": ["node_modules"]
}
