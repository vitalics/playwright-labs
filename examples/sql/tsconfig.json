{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "plugins": [
      {
        "_comment": "Approach 1: inline schema — quick for small projects, no extra files needed. Loaded first.",
        "name": "@playwright-labs/ts-plugin-sql",
        "tag": "sql",
        "schema": {
          "users": {
            "id": "number",
            "name": "string",
            "email": "string",
            "created_at": "string"
          },
          "posts": {
            "id": "number",
            "user_id": "number",
            "title": "string",
            "body": "string",
            "published": "boolean",
            "created_at": "string"
          },
          "comments": {
            "id": "number",
            "post_id": "number",
            "user_id": "number",
            "text": "string",
            "created_at": "string"
          }
        }
      },
      {
        "_comment": "Approach 2: schemaFile — schema generated by `fixture-sql pull`. Loaded second, so it wraps Approach 1 and takes precedence for completions/diagnostics on sql`...` templates.",
        "name": "@playwright-labs/ts-plugin-sql",
        "tag": "sql",
        "schemaFile": "./src/db-types.ts"
      }
    ]
  },
  "include": ["src/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
