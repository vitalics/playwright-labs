      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^host_user$/",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user)(pw_tests_total{host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "User",
          "refId": "A"
        }
      ],
