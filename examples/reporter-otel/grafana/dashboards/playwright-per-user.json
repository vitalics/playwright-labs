          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (host_user, le)(rate(pw_test_duration_milliseconds_bucket{host_user=~\"$user\"}[$__rate_interval])))",
