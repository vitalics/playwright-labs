          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user)(pw_test_duration_milliseconds_sum{host_user=~\"$user\"}) / sum by (host_user)(pw_test_duration_milliseconds_count{host_user=~\"$user\"})",
          "legendFormat": "{{host_user}}",
          "refId": "A"
        }
      ],
      "title": "Avg Test Duration — by User",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
