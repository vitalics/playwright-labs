    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 203,
      "title": "Leaderboard",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Tests Run" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Passed" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pass Rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.width", "value": 120 },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 80 },
                  { "color": "green", "value": 95 }
                ]
              }},
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Duration" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 130 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Tests Run" }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user, host_name, host_ip, os_platform)(pw_tests_total{host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "{{host_user}} | {{host_name}} | {{host_ip}} | {{os_platform}}",
          "refId": "Total",
          "hide": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user, host_name, host_ip, os_platform)(pw_tests_total{host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user)(pw_tests_total{test_result=\"pass\", host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user)(pw_tests_total{test_result=\"fail\", host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (sum by (host_user)(pw_tests_total{test_result=\"pass\", host_user=~\"$user\"}) or vector(0)) / (sum by (host_user)(pw_tests_total{host_user=~\"$user\"}) or vector(1))",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "D",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_user)(pw_test_duration_milliseconds_sum{host_user=~\"$user\"}) / sum by (host_user)(pw_test_duration_milliseconds_count{host_user=~\"$user\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "E",
          "format": "table"
        }
      ],
      "title": "Leaderboard — Users Summary",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "host_user": "User",
              "host_name": "Hostname",
              "host_ip": "IP",
              "os_platform": "Platform",
              "Value #A": "Tests Run",
              "Value #B": "Passed",
              "Value #C": "Failed",
              "Value #D": "Pass Rate %",
              "Value #E": "Avg Duration"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 204,
      "title": "Duration by User",
      "type": "row"
    },
