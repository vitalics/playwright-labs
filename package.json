{
  "name": "playwright-labs",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright Labs is a collection of packages that extend Playwright's functionality.",
  "scripts": {
    "test": "pnpm run -r --stream --parallel --color --if-present test",
    "build": "pnpm run -r --stream --color --if-present build",
    "package:pack:dry-run": "pnpm run -r --stream --color --if-present package:pack:dry-run",
    "ci:pretest": "pnpm run -r --stream --color --if-present ci:pretest",
    "ci:release": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.2",
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@types/node": "25.0.9",
    "tsup": "8.5.1",
    "tsx": "4.21.0"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "7.5.5",
      "rollup": "4.60.2",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "lodash": "4.18.1",
      "ajv": "8.18.0",
      "minimatch>brace-expansion": "2.0.3",
      "next": "16.2.4",
      "dockerode>uuid": "14.0.0"
    }
  }
}
