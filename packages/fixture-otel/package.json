{
  "name": "@playwright-labs/fixture-otel",
  "version": "1.0.1",
  "description": "OpenTelemetry fixtures and matchers for @playwright/test — use with @playwright-labs/reporter-otel",
  "keywords": [
    "playwright",
    "fixture",
    "opentelemetry",
    "otel",
    "metrics",
    "traces",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.13.0"
  },
  "dependencies": {
    "@playwright-labs/otel-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0"
  }
}
