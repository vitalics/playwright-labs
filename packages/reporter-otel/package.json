{
  "name": "@playwright-labs/reporter-otel",
  "version": "1.0.0",
  "description": "OpenTelemetry reporter for Playwright — send test metrics and traces to any OTEL-compatible backend",
  "keywords": [
    "playwright",
    "reporter",
    "opentelemetry",
    "otel",
    "otlp",
    "metrics",
    "traces",
    "monitoring",
    "grafana",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.13.0"
  },
  "dependencies": {
    "@playwright-labs/otel-core": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0"
  }
}
