{
  "name": "@playwright-labs/fixture-s3",
  "version": "0.0.0",
  "description": "S3 upload fixture for Playwright — useBucket() handle, shipped by @playwright-labs/reporter-s3",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "typecheck": "tsc --noEmit",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "keywords": [
    "playwright",
    "fixture",
    "testing",
    "playwright-labs",
    "s3",
    "upload"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitalics/playwright-labs.git",
    "directory": "packages/fixture-s3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.57.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@playwright-labs/s3-core": "workspace:*"
  }
}
