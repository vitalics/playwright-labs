{
  "name": "@playwright-labs/qrcode-core",
  "version": "1.0.0",
  "description": "QR code encode/decode primitives",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "keywords": [
    "qrcode",
    "encode",
    "decode",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitalics/playwright-labs.git",
    "directory": "packages/qrcode-core"
  },
  "packageManager": "pnpm@10.29.2",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "dependencies": {
    "jimp": "1.6.1",
    "jsqr": "1.4.0",
    "qrcode": "1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/qrcode": "1.5.6",
    "tsup": "^8.0.0"
  }
}
