{
  "name": "@playwright-labs/reporter-core",
  "version": "1.1.0",
  "description": "Base reporter class and shared types (TestCases, Template, StatusCounts) for @playwright-labs reporter packages",
  "keywords": [
    "playwright",
    "reporter",
    "base",
    "core",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.13.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0"
  }
}
