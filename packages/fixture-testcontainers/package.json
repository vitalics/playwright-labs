{
  "name": "@playwright-labs/fixture-testcontainers",
  "version": "1.0.0",
  "description": "Playwright fixture for Testcontainers — start Docker containers in tests with automatic cleanup",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "build": "tsup",
    "ci:pretest": "playwright install",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "peerDependencies": {
    "@playwright/test": ">=1.57.0",
    "testcontainers": ">=10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "testcontainers": "11.13.0"
  }
}
