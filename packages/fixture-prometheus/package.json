{
  "name": "@playwright-labs/fixture-prometheus",
  "version": "1.1.0",
  "description": "Prometheus metric fixtures (useCounterMetric, useGaugeMetric) for @playwright/test — use with @playwright-labs/reporter-prometheus-remote-write",
  "keywords": [
    "playwright",
    "fixture",
    "prometheus",
    "remote-write",
    "metrics",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.13.0"
  },
  "dependencies": {
    "@playwright-labs/prometheus-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0"
  }
}
