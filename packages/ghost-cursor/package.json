{
  "name": "@playwright-labs/ghost-cursor",
  "version": "1.0.0",
  "description": "Human-like mouse cursor movements for Playwright, ported from ghost-cursor",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 0",
    "build": "tsup",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "keywords": [
    "playwright",
    "ghost-cursor",
    "mouse",
    "cursor",
    "human-like",
    "bezier",
    "automation",
    "testing",
    "playwright-labs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@playwright/test": "1.57.0"
  },
  "peerDependencies": {
    "@playwright/test": "1.57.0"
  },
  "dependencies": {
    "bezier-js": "^6.1.4"
  }
}
