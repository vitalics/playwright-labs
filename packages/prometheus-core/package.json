{
  "name": "@playwright-labs/prometheus-core",
  "version": "0.0.0",
  "description": "Core Prometheus remote-write primitives (Counter, Gauge, stdout event bridge) for Playwright Labs",
  "keywords": [
    "playwright",
    "prometheus",
    "remote-write",
    "metrics",
    "grafana",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "dependencies": {
    "prometheus-remote-write": "0.5.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0"
  }
}
