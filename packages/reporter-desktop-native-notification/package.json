{
  "name": "@playwright-labs/reporter-desktop-native-notification",
  "version": "0.0.0",
  "description": "Desktop native notifications for Playwright test runs via node-notifier (macOS, Windows, Linux)",
  "keywords": [
    "playwright",
    "reporter",
    "notifications",
    "desktop",
    "node-notifier",
    "macos",
    "windows",
    "linux",
    "playwright-labs"
  ],
  "author": "Vitali Haradkou <vitalicset@yandex.ru>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsup",
    "test": "playwright test",
    "package:pack": "pnpm exec npm pack",
    "package:pack:dry-run": "pnpm package:pack --dry-run"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "@playwright/test": ">=1.13.0"
  },
  "dependencies": {
    "node-notifier": "10.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/node-notifier": "8.0.5"
  }
}
